{
  "expo": {
    "name": "Liftoff",
    "slug": "liftoff-clone",
    "scheme": "liftoff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06070D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eightx.liftoff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06070D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.eightx.liftoff"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
